// =====================================================
// schema.prisma — Modelo de Dados do SENAI-CIC
// Sistema de Gestão de Desempenho e Soft Skills
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- ENUM: Papéis de Acesso dos Usuários ----
enum Role {
  ADMIN // Acesso total ao sistema
  COLABORADOR // Acesso apenas ao próprio perfil
}

// ---- ENUM: Níveis de Avaliação Padronizados ----
// Seguem obrigatoriamente a escala de 1 a 4 definida pelo negócio
enum NivelAvaliacao {
  CRITICO // 1 - Vermelho
  EM_DESENVOLVIMENTO // 2 - Amarelo
  ATINGIU // 3 - Verde
  EXCEDEU // 4 - Azul
}

// ---- TABELA: Equipes ----
model Equipe {
  id        Int      @id @default(autoincrement())
  nome      String   @unique
  descricao String?
  criadoEm  DateTime @default(now())

  // Relação: uma equipe tem vários usuários
  usuarios Usuario[]
}

// ---- TABELA: Usuários ----
// Centraliza tanto admins quanto colaboradores
model Usuario {
  id           Int      @id @default(autoincrement())
  nome         String
  email        String   @unique
  senhaHash    String // Senha armazenada como hash bcrypt (NUNCA texto puro)
  cargo        String? // Ex: "Instrutor", "Supervisor"
  papel        Role     @default(COLABORADOR)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Relação com equipe (opcional — usuário pode não estar em equipe ainda)
  equipeId Int?
  equipe   Equipe? @relation(fields: [equipeId], references: [id])

  // Relações N:N com avaliações:
  // Um usuário pode ter FEITO muitas avaliações (como avaliador)
  avaliacoesFeitas    Avaliacao[] @relation("Avaliador")
  // Um usuário pode ter RECEBIDO muitas avaliações (como avaliado)
  avaliacoesRecebidas Avaliacao[] @relation("Avaliado")
}

// ---- TABELA: Ciclos de Avaliação ----
// Representa um período de avaliação (ex: "Q1 2024 - Jan a Mar")
model CicloAvaliacao {
  id          Int      @id @default(autoincrement())
  nome        String
  dataInicio  DateTime
  dataFim     DateTime
  tipoPeriodo String   @default("MENSAL") // Ex: "MENSAL", "TRIMESTRAL", "SEMESTRAL"
  // Ciclos fechados NÃO podem ser editados (regra de negócio crítica)
  fechado     Boolean  @default(false)
  criadoEm    DateTime @default(now())

  // Um ciclo contém várias avaliações
  avaliacoes Avaliacao[]
}

// ---- TABELA: Competências / Soft Skills ----
// Catálogo de habilidades que podem ser avaliadas
model Competencia {
  id        Int     @id @default(autoincrement())
  nome      String  @unique // Ex: "Trabalho em Equipe", "Comunicação"
  descricao String?
  categoria String? // Ex: "Interpessoal", "Liderança"
  ativo     Boolean @default(true)

  // Uma competência pode aparecer em muitas avaliações
  avaliacoes Avaliacao[]
}

// ---- ENUM: Tipos de Avaliação ----
enum TipoAvaliacao {
  AUTO // Autoavaliação
  LIDER // Avaliação da Liderança
  PAR // Avaliação 360° (Colega)
}

// ---- TABELA: Avaliações (Tabela de Junção N:N) ----
// Esta tabela implementa a relação N:N entre Usuários:
//   - Um usuário (avaliador) avalia MUITOS outros (avaliados)
//   - Um usuário (avaliado) é avaliado por MUITOS outros (avaliadores)
// A combinação avaliadorId + avaliadoId + cicloId + competenciaId + tipo deve ser única
model Avaliacao {
  id           Int            @id @default(autoincrement())
  pontuacao    Int // Valor numérico: agora de 1 a 10
  nivel        NivelAvaliacao // Nível padronizado correspondente à pontuação
  tipo         TipoAvaliacao  @default(PAR)
  anonimo      Boolean        @default(true) // Flag para definir se a avaliação é anônima
  observacoes  String? // Comentário opcional do avaliador (anônimo no frontend)
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt

  // Relação com o avaliador (quem fez a avaliação)
  // O frontend 360° NUNCA deve expor este campo para o avaliado
  avaliadorId Int
  avaliador   Usuario @relation("Avaliador", fields: [avaliadorId], references: [id])

  // Relação com o avaliado (quem recebeu a avaliação)
  avaliadoId Int
  avaliado   Usuario @relation("Avaliado", fields: [avaliadoId], references: [id])

  // Relação com o ciclo de avaliação
  cicloId Int
  ciclo   CicloAvaliacao @relation(fields: [cicloId], references: [id])

  // Relação com a competência avaliada
  competenciaId Int
  competencia   Competencia @relation(fields: [competenciaId], references: [id])

  // Garante que um avaliador só possa avaliar a mesma competência
  // de um avaliado uma única vez por ciclo por tipo
  @@unique([avaliadorId, avaliadoId, cicloId, competenciaId, tipo])
  @@index([avaliadoId, cicloId]) // Índice para acelerar buscas do dashboard
}
