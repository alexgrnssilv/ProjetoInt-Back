# URL de conexão com o PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:meubanco@localhost:5432/meuprojeto"

# Chave secreta para assinar os tokens JWT (use uma string longa e aleatória em produção)
JWT_SECRET="senai_cic_secret_super_seguro_2024"

# Tempo de expiração do token JWT (ex: 1d = 1 dia, 7d = 7 dias)
JWT_EXPIRES_IN="1d"

# Porta em que o servidor vai rodar
PORT=3001
